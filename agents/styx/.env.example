# ── Obol API ──
OBOL_URL=https://your-obol-instance.up.railway.app
SOLANA_RPC=https://api.mainnet-beta.solana.com

# ── Agent Wallet (for paying Obol endpoints) ──
# base58 encoded Solana keypair with USDC balance
# Omit to run in discovery mode (no payments)
# AGENT_PRIVATE_KEY=

# ── Twitter / X API ──
# OAuth 1.0a credentials from developer.x.com
# Omit to run in dry-run mode (tweets printed to console)
TWITTER_APP_KEY=your_app_key
TWITTER_APP_SECRET=your_app_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
OBOL_INTERNAL_KEY=your_internal_key

# ── Optional ──
# STYX_LOG_LEVEL=quiet    # suppress debug output
