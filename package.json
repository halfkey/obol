{
  "name": "obol-mcp",
  "version": "2.0.1",
  "description": "Pay the ferryman. Solana agent gateway via x402. MCP server for AI agents.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "mcp": "tsx src/mcp.ts",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "obol-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "solana",
    "x402",
    "api",
    "gateway",
    "micropayments",
    "agent",
    "obol",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "usdc",
    "defi"
  ],
  "author": "halfkey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/halfkey/obol.git"
  },
  "homepage": "https://github.com/halfkey/obol",
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.8",
    "@upstash/redis": "^1.35.6",
    "@x402/core": "^2.6.0",
    "@x402/svm": "^2.6.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "twitter-api-v2": "^1.29.0",
    "utf-8-validate": "^6.0.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "mcpName": "io.github.halfkey/obol"
}
